# Copy this file to config/lab.env and fill in your values.
# config/lab.env is gitignored so tokens stay local.

# Git remote for ArgoCD and Tekton (HTTPS recommended)
GIT_REPO_URL=https://github.com/YOUR_USER/polaris-pipeline.git
GIT_BRANCH=main

# Image tag for the next pipeline run (bump on each release)
IMAGE_TAG=v0.1.1

# Cluster type: kind | minikube
CLUSTER_TYPE=kind

# KIND settings
KIND_CLUSTER_NAME=polaris
REGISTRY_PORT=5000

# Registry URLs (auto-set by configure-manifests.sh if left empty)
REGISTRY_PULL=localhost:5000
REGISTRY_PUSH=host.docker.internal:5000

# minikube settings (only if CLUSTER_TYPE=minikube)
MINIKUBE_PROFILE=minikube

# GitHub PAT — required for Tekton to push manifest updates
# See docs/09-github-token.md
GIT_TOKEN=
